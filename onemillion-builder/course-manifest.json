      "primary_agent": "build",
      "supporting_agents": ["ask", "debug"],
      "lesson": "onemillion-builder/week-1-foundation/day-05-auth/learn.md",
      "build": "onemillion-builder/week-1-foundation/day-05-auth/build.md",
      "resources": "onemillion-builder/week-1-foundation/day-05-auth/resources.md",
      "verifier": "onemillion-builder/week-1-foundation/day-05-auth/ai-instructions-day-05.md",
