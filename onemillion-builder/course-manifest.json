      "resources": "onemillion-builder/week-1-foundation/day-04-stack/resources.md",
      "verifier": "onemillion-builder/week-1-foundation/day-04-stack/ai-instructions-day-04.md",
      "learning_focus": ["understand the stack", "create a Next.js app", "use GitHub", "deploy to Vercel"],
