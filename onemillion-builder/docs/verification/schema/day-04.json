{
  "day": 4,
  "title": "Design The Product",
  "structural_checks": [
    {
      "id": "design_spec_exists",
      "type": "file_exists",
      "path": ".onemillion/design-spec.md"
    },
    {
      "id": "design_system_exists",
      "type": "file_exists",
      "path": ".onemillion/design-system.md"
    },
    {
      "id": "screens_directory_exists",
      "type": "directory_exists",
      "path": ".onemillion/screens"
    },
    {
      "id": "screen_specs_exist",
      "type": "file_exists_glob",
      "patterns": [".onemillion/screens/*.md"],
      "min_match_count": 2
    },
    {
      "id": "seed_data_exists",
      "type": "file_exists",
      "path": ".onemillion/seed-data.json"
    },
    {
      "id": "seed_data_valid_json",
      "type": "valid_json",
      "path": ".onemillion/seed-data.json"
    },
    {
      "id": "globals_css_exists",
      "type": "file_exists",
      "path": ".onemillion/globals.css"
    },
    {
      "id": "mockup_exists",
      "type": "file_exists",
      "path": ".onemillion/mockup/index.html"
    }
  ],
  "code_quality_checks": [
    {
      "id": "design_spec_sections",
      "type": "markdown_required_sections",
      "path": ".onemillion/design-spec.md",
      "required_headings": [
        "Design Direction",
        "Primary User Flow",
        "Screens",
        "Content States",
        "Responsive"
      ]
    },
    {
      "id": "design_system_sections",
      "type": "markdown_required_sections",
      "path": ".onemillion/design-system.md",
      "required_headings": [
        "Color",
        "Typography",
        "Spacing",
        "Components",
        "Motion",
        "Accessibility"
      ]
    },
    {
      "id": "design_mentions_mui_or_material",
      "type": "file_contains",
      "path": ".onemillion/design-system.md",
      "any_of_strings": ["MUI", "Material Design", "Material UI"]
    },
    {
      "id": "states_are_defined",
      "type": "file_contains",
      "path": ".onemillion/design-spec.md",
      "required_strings": ["Loading", "Empty", "Error"],
      "any_of_strings": ["Partial", "Full", "Success"]
    },
    {
      "id": "responsive_behavior_defined",
      "type": "file_contains",
      "path": ".onemillion/design-spec.md",
      "any_of_strings": ["mobile", "Mobile", "desktop", "Desktop", "responsive", "Responsive", "tablet", "Tablet"]
    }
  ],
  "manual_checks": [
    {
      "id": "mockup_reviewed",
      "ask": "Did you review the Day 4 mockup or screen specs and confirm they match your intended product direction?"
    },
    {
      "id": "design_direction_approved",
      "ask": "Did you approve the design direction, or request and complete revisions before moving on?"
    }
  ]
}
