{
  "day": 5,
  "title": "Plan Architecture",
  "structural_checks": [
    {
      "id": "architecture_exists",
      "type": "file_exists",
      "path": ".onemillion/architecture.md"
    },
    {
      "id": "sprints_directory_exists",
      "type": "directory_exists",
      "path": ".onemillion/sprints"
    },
    {
      "id": "sprint_briefs_exist",
      "type": "file_exists_glob",
      "patterns": [".onemillion/sprints/*.md"],
      "min_match_count": 1
    }
  ],
  "code_quality_checks": [
    {
      "id": "architecture_sections",
      "type": "markdown_required_sections",
      "path": ".onemillion/architecture.md",
      "required_headings": [
        "Backend Path",
        "Data Model",
        "API",
        "Frontend",
        "Deployment"
      ]
    },
    {
      "id": "backend_path_recorded",
      "type": "file_contains",
      "path": ".onemillion/architecture.md",
      "any_of_strings": [
        "Supabase-only",
        "Supabase only",
        "FastAPI"
      ]
    },
    {
      "id": "course_stack_named",
      "type": "file_contains",
      "path": ".onemillion/architecture.md",
      "required_strings": ["Next.js", "Supabase", "Vercel"],
      "any_of_strings": ["MUI", "Material Design", "Material UI"]
    },
    {
      "id": "sprint_brief_has_build_contract",
      "type": "file_contains",
      "path_pattern": ".onemillion/sprints/*.md",
      "any_of_strings": [
        "Acceptance Criteria",
        "Verification Gate",
        "Design Notes"
      ]
    }
  ],
  "manual_checks": [
    {
      "id": "backend_path_approved",
      "ask": "Did you approve the backend path decision: Supabase-only unless FastAPI is clearly justified?"
    },
    {
      "id": "plan_validation_complete",
      "ask": "Did validate-plan pass, or were its findings resolved before moving to build?"
    }
  ]
}
