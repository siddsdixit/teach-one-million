{
  "day": 6,
  "title": "App Shell + First Deploy",
  "structural_checks": [
    {
      "id": "package_json_exists",
      "type": "file_exists",
      "path": "package.json"
    },
    {
      "id": "next_react_mui_in_dependencies",
      "type": "json_field_contains",
      "path": "package.json",
      "field": "dependencies",
      "required_keys": ["next", "react", "@mui/material"]
    },
    {
      "id": "app_page_exists",
      "type": "file_exists",
      "path": "app/page.tsx"
    },
    {
      "id": "app_page_customized",
      "type": "file_not_contains",
      "path": "app/page.tsx",
      "blocked_strings": ["Get started by editing"]
    },
    {
      "id": "gitignore_set",
      "type": "file_contains",
      "path": ".gitignore",
      "required_strings": ["node_modules", ".env.local"]
    },
    {
      "id": "git_initialized",
      "type": "directory_exists",
      "path": ".git"
    }
  ],
  "code_quality_checks": [
    {
      "id": "mui_used_in_app",
      "type": "file_contains",
      "path_pattern": "app/**/*.tsx",
      "any_of_strings": ["@mui/material", "ThemeProvider", "CssBaseline"]
    }
  ],
  "remote_checks": [
    {
      "id": "git_remote_set",
      "type": "shell_command",
      "command": "git remote -v",
      "expected_pattern": "github.com"
    },
    {
      "id": "vercel_url_responds",
      "type": "http_check",
      "url_source": "ask_builder",
      "url_prompt": "What is your Vercel URL?",
      "expected_status": [200, 304]
    },
    {
      "id": "deployment_matches_homepage_source",
      "type": "deployment_matches_source",
      "url_source": "ask_builder",
      "source_paths": ["app/page.tsx"],
      "min_marker_count": 1,
      "expected_status": [200, 304],
      "note": "Fetches the live deployment and confirms at least one meaningful text marker from app/page.tsx appears in the deployed page."
    }
  ]
}
