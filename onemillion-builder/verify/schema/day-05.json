{
  "day": 5,
  "title": "Auth + Database",
  "structural_checks": [
    {
      "id": "supabase_libs_installed",
      "type": "json_field_contains",
      "path": "package.json",
      "field": "dependencies",
      "required_keys": ["@supabase/supabase-js", "@supabase/ssr"]
    },
    {
      "id": "env_local_exists",
      "type": "file_exists",
      "path": ".env.local"
    },
    {
      "id": "supabase_env_vars",
      "type": "file_contains",
      "path": ".env.local",
      "required_strings": ["NEXT_PUBLIC_SUPABASE_URL", "NEXT_PUBLIC_SUPABASE_ANON_KEY"]
    },
    {
      "id": "env_local_gitignored",
      "type": "file_contains",
      "path": ".gitignore",
      "required_strings": [".env.local"]
    },
    {
      "id": "signup_page_exists",
      "type": "file_exists_glob",
      "patterns": ["app/signup/page.tsx", "app/(auth)/signup/page.tsx"]
    },
    {
      "id": "login_page_exists",
      "type": "file_exists_glob",
      "patterns": ["app/login/page.tsx", "app/(auth)/login/page.tsx"]
    },
    {
      "id": "auth_callback_exists",
      "type": "file_exists_glob",
      "patterns": ["app/auth/callback/route.ts", "app/auth/callback/route.tsx"]
    },
    {
      "id": "dashboard_exists",
      "type": "file_exists_glob",
      "patterns": ["app/dashboard/page.tsx", "app/(protected)/dashboard/page.tsx"]
    },
    {
      "id": "middleware_exists",
      "type": "file_exists",
      "path": "middleware.ts"
    },
    {
      "id": "supabase_client_utility",
      "type": "file_exists_glob",
      "patterns": ["lib/supabase/client.ts", "lib/supabase/server.ts", "utils/supabase/client.ts"]
    }
  ],
  "code_quality_checks": [
    {
      "id": "signup_uses_supabase_auth",
      "type": "file_contains",
      "path_pattern": "app/**/signup/page.tsx",
      "required_strings": ["signUp"]
    },
    {
      "id": "login_uses_supabase_auth",
      "type": "file_contains",
      "path_pattern": "app/**/login/page.tsx",
      "required_strings": ["signInWithPassword"]
    },
    {
      "id": "middleware_refreshes_session",
      "type": "file_contains",
      "path": "middleware.ts",
      "required_strings": ["supabase", "getUser"]
    }
  ],
  "manual_checks": [
    {
      "id": "vercel_env_vars_set",
      "ask": "Did you add NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY to your Vercel project's Environment Variables?"
    },
    {
      "id": "rls_enabled",
      "ask": "Did you enable Row Level Security on your first table in Supabase?"
    },
    {
      "id": "rls_policy_exists",
      "ask": "Did you add at least one RLS policy that uses auth.uid()?"
    }
  ],
  "remote_checks": [
    {
      "id": "live_signup_responds",
      "type": "http_check",
      "url_source": "build_from_vercel_base",
      "path_suffix": "/signup",
      "expected_status": [200, 304]
    }
  ]
}
